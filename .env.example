APP_NAME=AgentPilot
APP_VERSION=3.0.0
ENVIRONMENT=local

DATABASE_URL=postgresql+asyncpg://agentpilot:agentpilot@agentpilot-postgres:5432/agentpilot
REDIS_URL=redis://agentpilot-redis:6379/0
MINIO_ENDPOINT=agentpilot-minio:9000

LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=ollama
LLM_DEFAULT_MODEL=qwen2.5:7b

EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSIONS=1024

MULTIMODAL_EMBEDDING_BASE_URL=
MULTIMODAL_EMBEDDING_API_KEY=
MULTIMODAL_EMBEDDING_MODEL=
MULTIMODAL_EMBEDDING_DIMENSIONS=768

MINIO_ACCESS_KEY=agentpilot
MINIO_SECRET_KEY=agentpilot123
MINIO_BUCKET=agentpilot-images
MINIO_SECURE=false

# 向量数据库配置（pgvector / qdrant）
VECTOR_DB_BACKEND=pgvector
QDRANT_URL=http://localhost:6333

# 安全与限流
ENCRYPTION_KEY=agentpilot-encryption-key-change-in-production
RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT=5/minute

# RAG 参数
CHUNK_SIZE=800
CHUNK_OVERLAP=120
MAX_FILE_SIZE=10485760
MAX_TEXT_LENGTH=8000
OCR_SCANNED_THRESHOLD=50

# Embedding 超时
EMBEDDING_TIMEOUT=60
EMBEDDING_BATCH_TIMEOUT=120

# 鉴权配置
JWT_SECRET_KEY=agentpilot-dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
AUTH_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 上下文压缩
CONTEXT_TOKEN_THRESHOLD=6000
RECENT_TURNS=6

# OCR 配置
OCR_ENABLED=true
OCR_LANGUAGE=chi_sim+eng
OCR_DPI=200

# 检索阈值
RETRIEVAL_MIN_SCORE=0.3
RETRIEVAL_MIN_LEXICAL_SCORE=0.3
